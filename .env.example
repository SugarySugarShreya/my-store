# Copy this file to .env.local for local development.
# In production, set all of these in Vercel:
# Project → Settings → Environment Variables
#
# Never commit a real .env file — only this .env.example template.

# ---- Razorpay (payments) ----
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ---- Shipmozo (shipping) ----
# See SHIPMOZO-SETUP.md for how to get these.
SHIPMOZO_PUBLIC_KEY=
SHIPMOZO_PRIVATE_KEY=
SHIPMOZO_WAREHOUSE_ID=

# ---- Google Sheets order log (optional) ----
# See GOOGLE-SHEETS-SETUP.md. Also receives customer-uploaded
# customization photos/notes for personalized products.
GOOGLE_SHEET_WEBHOOK_URL=
